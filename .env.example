# =============================================================
# RIOMS — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================

# ------------------------------------------------------------------
# MongoDB Connection (leave blank to use in-memory store for dev)
# ------------------------------------------------------------------
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/rioms?retryWrites=true&w=majority

# ------------------------------------------------------------------
# Session / JWT Secret
# IMPORTANT: Change this to a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------------
SESSION_SECRET=dev-insecure-secret-change-me-in-production

# ------------------------------------------------------------------
# Next.js base URL (used for absolute URLs in emails, webhooks, etc.)
# ------------------------------------------------------------------
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
